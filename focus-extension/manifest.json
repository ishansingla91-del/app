{
  "manifest_version": 3,
  "name": "Focus Guard",
  "version": "2.1.0",
  "description": "Strict focus blocker with educational-only YouTube mode, PIN controls, and anti-bypass safeguards.",
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "notifications",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://youtube.com/*",
    "*://*.instagram.com/*",
    "*://*.facebook.com/*",
    "*://*.reddit.com/*",
    "*://*.x.com/*",
    "*://*.twitter.com/*",
    "*://*.tiktok.com/*",
    "*://*.twitch.tv/*",
    "*://*.discord.com/*",
    "*://*.netflix.com/*",
    "*://*.primevideo.com/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "focus_blocking_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://youtube.com/*"
      ],
      "js": [
        "content.js",
        "youtube-filter.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "*://*.instagram.com/*",
        "*://*.facebook.com/*",
        "*://*.reddit.com/*",
        "*://*.x.com/*",
        "*://*.twitter.com/*",
        "*://*.tiktok.com/*",
        "*://*.twitch.tv/*",
        "*://*.discord.com/*",
        "*://*.netflix.com/*",
        "*://*.primevideo.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "block.html",
        "block.css",
        "block.js",
        "keywords.json",
        "channels.json"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
